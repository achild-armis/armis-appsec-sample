          "ruleId": "gxU1bd_amer_47293171_armis-appsec-sample/sample-file.py_38_5_38_24_gxU1bd",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "The code starts the Flask application with `app.run(debug=True)` (line 38): The code starts the Flask application with `app.run(debug=True)` (line 38). Enabling the `debug` flag in Flask activates the built‑in debugger and automatic reloader, which expose detailed stack traces, environment variables, and source code through the web interface. Because the application is served over HTTP, an external attacker can trigger errors or interact with the debugger to obtain sensitive internal information. This matches CWE‑489 (Active Debug Code), which specifically warns against deploying Flask with `debug=True`. The vulnerability is directly reachable via the public HTTP service, giving it an exposure level of 6 and a high likelihood of exploitation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "sample-file.py"
                },
                "region": {
                  "startLine": 38,
                  "startColumn": 5
                }
              }
            }
          ],
          "properties": {
            "severity": "HIGH",
            "type": "VULNERABILITY",
            "cwes": [
              "CWE-489: Active Debug Code"
            ],
            "fix": {
              "isValid": false,
              "patch": "--- armis-appsec-sample/sample-file.py\n+++ armis-appsec-sample/sample-file.py\n@@ -15,6 +15,9 @@\n     query = f\"SELECT * FROM users WHERE username = '{username}' AND password = '********[10-20]'\"\n     cursor.execute(query)\n     user = cursor.fetchone()\n+File: armis-appsec-sample/sample-file.py (Lines 18-38)\n     conn.close()\n     if user:\n         return \"Login successful!\"\n@@ -35,4 +38,4 @@\n     return \"Welcome! Try `/login` or `/get_file/\u003cfilename\u003e`\"\n \n if __name__ == '__main__':\n-    app.run(debug=True)+    app.run(debug=False)"
            }
          }
